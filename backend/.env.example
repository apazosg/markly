DB_PASSWORD=cambia_esto

# JSON completo de la cuenta de servicio Firebase (en una sola línea, sin saltos de línea)
# Descárgalo desde Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SA_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"..."}

# API key de Deepgram — console.deepgram.com → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key

# API key de Gemini — aistudio.google.com → API keys
GEMINI_API_KEY=your_gemini_api_key

# Token del túnel de Cloudflare — cloudflare.com → Zero Trust → Tunnels
# Omite este servicio del docker-compose si no usas Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token
